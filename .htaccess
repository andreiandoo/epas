# bilete.online Marketplace - Apache Configuration
# Enable URL rewriting
RewriteEngine On

# Set default index file
DirectoryIndex index.php index.html

# Force HTTPS (uncomment in production once cert is live)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ============================================
# ROMANIAN URL STRUCTURE - LEISURE / AGREMENT
# ============================================

# Event detail pages - /bilete/event-slug
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^bilete/([a-z0-9-]+)/?$ event.php?slug=$1 [L,QSA]

# Legacy: redirect /event/slug to /bilete/slug
RewriteRule ^event/([a-z0-9-]+)/?$ /bilete/$1 [R=301,L,QSA]

# Category & city single-segment URLs.
# Both `/escape-rooms` (category) and `/bucuresti` (city) match `^[a-z][a-z0-9-]+$`.
# category.php is the resolver — it queries the API; if the slug matches a
# category, it renders the category page; otherwise it falls through to
# city.php (which renders a city page or returns 404 if neither matches).
# Defined further down in the catch-all section to allow named routes
# (organizator/*, cont/*, cos, finalizare, etc.) to claim their paths first.

# Legacy: redirect /category/slug to /slug
RewriteRule ^category/([a-z0-9-]+)/?$ /$1 [R=301,L,QSA]

# All categories listing
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^categorii/?$ categorii.php [L,QSA]

# How it works
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^cum-functioneaza/?$ cum-functioneaza.php [L,QSA]

# All events listing
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^evenimente/?$ events.php [L,QSA]

# Past events
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^evenimente-trecute/?$ past-events.php [L,QSA]

# Venues / locations
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^locatii/?$ venues.php [L]

# Venue type pages
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^locatii/([a-z0-9-]+)/?$ venue-type.php?type=$1 [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^locatie/([a-z0-9-]+)/?$ venue-single.php?slug=$1 [L,QSA]

# Legacy: redirect /venues to /locatii
RewriteRule ^venues/?$ /locatii [R=301,L,QSA]

# Cities / regions
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^orase/?$ cities.php [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^regiune/([a-z0-9-]+)/?$ region.php?slug=$1 [L,QSA]

# Legacy redirects
RewriteRule ^region/([a-z0-9-]+)/?$ /regiune/$1 [R=301,L,QSA]
RewriteRule ^cities/?$ /orase [R=301,L,QSA]

